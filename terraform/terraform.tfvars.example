# Example variables for creating the Kubernetes node VM.
# Copy this file to terraform.tfvars and fill in your actual values.

vm_name          = "devops-k8s-node"
# Replace with the full path to your .vbox file
vm_template_path = "C:/Users/YourUser/VirtualBox VMs/ubuntu-22.04-template/ubuntu-22.04-template.vbox"
vm_cpu           = 2
vm_memory        = 4096
vm_disk          = 40
ssh_user         = "ubuntu"
ssh_public_key   = "ssh-rsa AAAA..."
ssh_password     = "your-vm-password"
