# .env.example
# Rename this file to .env and fill in your values

# PostgreSQL
POSTGRES_DB=tasks_db
POSTGRES_USER=user
# POSTGRES_PASSWORD will be managed via Docker Compose Secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Worker
WORKER_DEMO_MODE=1
WORKER_PROCESSING_DELAY_SECONDS=8
WORKER_LOOP_SLEEP_SECONDS=1
WORKER_AUTOPROCESS_ENABLED=0
# 0..1 probability of random task failure in worker (for demo/testing)
WORKER_FAILURE_RATE=0
WORKER_METRICS_PORT=9102

# API Service
API_PORT=8000
API_LOG_HEALTHCHECKS=0
API_LOG_UI_POLLING=0

# Live simulator (illusion of manual actions)
SIMULATOR_ENABLED=1
SIMULATOR_API_BASE_URL=http://api:8000
SIMULATOR_TASK_TITLE_PREFIX=Live Task
SIMULATOR_CREATE_MIN_DELAY_SECONDS=15
SIMULATOR_CREATE_MAX_DELAY_SECONDS=30
SIMULATOR_STAGE_MIN_DELAY_SECONDS=15
SIMULATOR_STAGE_MAX_DELAY_SECONDS=30
SIMULATOR_FAIL_RATE=0.2
SIMULATOR_FAIL_TAG_RATE=0.35
SIMULATOR_BURST_SIZE=3
SIMULATOR_MAX_TASKS=60
SIMULATOR_CLEANUP_INTERVAL_SECONDS=15

# Frontend Service
FRONTEND_PORT=3000

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Private Docker Registry
REGISTRY_PORT=5000

# Grafana
GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD will be managed via Docker Compose Secret

# Local Jenkins (optional, only for docker-compose.jenkins.yml)
JENKINS_ADMIN_USER=admin
# Set your own strong password for local Jenkins.
JENKINS_ADMIN_PASSWORD=
