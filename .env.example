# .env.example
# Rename this file to .env and fill in your values

# PostgreSQL
POSTGRES_DB=tasks_db
POSTGRES_USER=user
# POSTGRES_PASSWORD will be managed via Docker Compose Secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API Service
API_PORT=8000

# Frontend Service
FRONTEND_PORT=3000

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Private Docker Registry
REGISTRY_PORT=5000

# Grafana
GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD will be managed via Docker Compose Secret
