# .env.example
# Rename this file to .env and fill in your values

# PostgreSQL
POSTGRES_DB=tasks_db
POSTGRES_USER=user
# POSTGRES_PASSWORD will be managed via Docker Compose Secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Worker
WORKER_PROCESSING_DELAY_SECONDS=5
# 0..1 probability of random task failure in worker (for demo/testing)
WORKER_FAILURE_RATE=0
WORKER_METRICS_PORT=9102

# API Service
API_PORT=8000

# Frontend Service
FRONTEND_PORT=3000

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Private Docker Registry
REGISTRY_PORT=5000

# Grafana
GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD will be managed via Docker Compose Secret

# Local Jenkins (optional, only for docker-compose.jenkins.yml)
JENKINS_ADMIN_USER=admin
# Set your own strong password for local Jenkins.
JENKINS_ADMIN_PASSWORD=
